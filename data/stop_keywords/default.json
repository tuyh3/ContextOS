        "COM",
        "ACK",
        "NACK",
        "AIT",
        "CSC",
        "MML",
        "PACKAGE"
      ]
    },
    "document_template_words": {
      "reason": "Appear in every Product Paper / MOP / FPA template heading and metadata",
      "keywords": [
        "PRODUCT",
        "PAPER",
        "PRD",
        "MOP",
        "SOP",
        "FPA",
        "TOC",
