# ContextOS 凭证模板。复制本文件为 .env 后填实际值。.env 已被 .gitignore 排除。

# === LLM(真 LLM 测试 / smoke 必填)===
# 变量名 = profile.toml [llm].api_key_env。当前 profile 用 deepseek -> DEEPSEEK_API_KEY。
# 从 https://platform.deepseek.com 后台生成 key 填这里。换 provider 则改成对应的 *_API_KEY。
DEEPSEEK_API_KEY=<your_deepseek_api_key>
# ANTHROPIC_API_KEY=<your_key>   # 若 profile [llm].provider=claude 改用这个

# === Oracle 测试库凭证 ===
# 任何不在 profile.toml [oracle].allowed_instances 列表里的实例,即使填了凭证,
# contextos/db_provider/sqlcl_mcp.py 也会在运行时拒绝连接。

# TEST_DB1
ORACLE_TEST_DB1_USER=<your_user>
ORACLE_TEST_DB1_PASSWORD=<your_password>

# TEST_DB2
ORACLE_TEST_DB2_USER=<your_user>
ORACLE_TEST_DB2_PASSWORD=<your_password>

# TEST_DB3
ORACLE_TEST_DB3_USER=<your_user>
ORACLE_TEST_DB3_PASSWORD=<your_password>

# TNS_ADMIN 也可以用 env 覆盖(默认从 profile.toml [oracle].tns_admin 读)
# TNS_ADMIN=<absolute path to dir containing tnsnames.ora>
